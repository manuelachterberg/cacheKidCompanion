<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F7F2DE"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/geocachingLoginTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Geocaching-Login"
            android:textColor="#151515"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/geocachingLoginStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Bitte in Geocaching einloggen und danach unten bestaetigen."
            android:textColor="#5D5D55"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/geocachingLoginCancelButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Abbrechen" />

            <Button
                android:id="@+id/geocachingLoginDoneButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Login uebernehmen" />
        </LinearLayout>
    </LinearLayout>

    <WebView
        android:id="@+id/geocachingLoginWebView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
